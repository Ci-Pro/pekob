# ── PEKOB Environment Variables ──────────────────────────────
# Set these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Neon Database (pooled connection for application)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR_PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Neon Direct URL (for Prisma migrations, bypasses pooler)
DIRECT_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR_PROJECT.REGION.aws.neon.tech/neondb?sslmode=require"

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-random-secret-here"

# NextAuth URL (set to your Vercel URL, e.g. https://pekob.vercel.app)
NEXTAUTH_URL="https://your-app.vercel.app"

# Cloudinary (for video & image hosting)
# Get credentials at: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
